{
  "manifest_version": 3,
  "name": "TrailRoam for Komoot",
  "description": "Import Komoot tours locally and view routes in a full-page extension app.",
  "version": "1.0.0",
  "icons": {
    "16": "app/assets/trailroam-logo-16.png",
    "32": "app/assets/trailroam-logo-32.png",
    "48": "app/assets/trailroam-logo-48.png",
    "128": "app/assets/trailroam-logo-128.png",
    "256": "app/assets/trailroam-logo-256.png"
  },
  "action": {
    "default_title": "Trailroam for Komoot",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "app/assets/trailroam-logo-16.png",
      "32": "app/assets/trailroam-logo-32.png",
      "48": "app/assets/trailroam-logo-48.png",
      "128": "app/assets/trailroam-logo-128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
    "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://api.komoot.de/*",
    "https://tiles.openfreemap.org/*"
  ]
}
